# ============================================================
# korea-finance-mcp — Environment Variables
# ============================================================
# 사용법:
#   1. 이 파일을 `.env`로 복사
#   2. 아래 값들을 본인의 키로 채움
#   3. `.env`는 .gitignore에 등재되어 있음 (절대 commit 금지)
# ============================================================

# 한국은행 ECOS API 키 (필수)
# 발급: https://ecos.bok.or.kr/api/
# 무료, 일일 10만 호출, 자동 승인 (1일 이내)
ECOS_API_KEY=

# (선택) ECOS API 베이스 URL — 기본값 사용 권장
# ECOS_BASE_URL=https://ecos.bok.or.kr/api

# (선택) 응답 캐시 TTL (초). 기본 3600 (1시간)
# CACHE_TTL_SECONDS=3600

# (선택) Rate limit — 초당 최대 호출 수. 기본 5
# RATE_LIMIT_PER_SECOND=5

# ============================================================
# v2.0 부동산 (5주차 추가 예정 — 미리 준비)
# ============================================================
# DATA_GO_KR_API_KEY=  # 국토교통부 공공데이터포털
# REB_API_KEY=         # 한국부동산원 R-ONE

# ============================================================
# v3.0 주식 (9주차 추가 예정 — 미리 준비)
# ============================================================
# DART_API_KEY=        # 금융감독원 OpenDART
