#!/usr/bin/env bash
# ============================================================
# korea-finance-mcp — pre-push hook
# ============================================================
# Push 전 자동 검증 — WO-005 / WO-008 / WO-009 학습 결과
#
# 두 번의 핫픽스 사례에서 학습:
#   - WO-005 (unhandled rejection): push 동반으로 운명적 회피
#   - WO-008 (disclaimer false positive): 단독 push로 CI #5 FAIL history 영구 기록
#
# 본 hook은 push *전*에 npm run test를 실행하여 두 사례를 사전 차단.
# Vitest exit code 1 (Tests failed OR Errors > 0) 시 push 자동 차단.
#
# 활성화 (각 개발자 1회 설정):
#   git config core.hooksPath .githooks
#
# 비활성화 (긴급 시만, *권장 안 함*):
#   git push --no-verify
# ============================================================

set -e

# 색상 (Windows PowerShell도 호환)
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo ""
echo -e "${YELLOW}🛡 [pre-push] 회귀 테스트 자동 검증 시작...${NC}"
echo -e "${YELLOW}   (WO-005·WO-008 학습 — Tests passed + Errors 0 강제)${NC}"
echo ""

# typecheck 먼저 (빠른 fail)
if ! npm run typecheck --silent; then
  echo ""
  echo -e "${RED}❌ [pre-push] TypeScript strict 검사 실패 — push 차단${NC}"
  echo -e "${RED}   CONTRIBUTING.md §5 자가 점검 체크리스트 참조${NC}"
  exit 1
fi

# 회귀 테스트 (Vitest)
if ! npm run test --silent; then
  echo ""
  echo -e "${RED}❌ [pre-push] 회귀 테스트 실패 — push 차단${NC}"
  echo -e "${RED}   Tests passed 줄 + Errors 0 줄 둘 다 확인 필요${NC}"
  echo -e "${RED}   CONTRIBUTING.md §5 / wiki/korea-finance-mcp/work-orders.md WO-005·WO-008 참조${NC}"
  exit 1
fi

echo ""
echo -e "${GREEN}✅ [pre-push] 회귀 통과 + typecheck 통과. push 진행.${NC}"
echo ""

exit 0
